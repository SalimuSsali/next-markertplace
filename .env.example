# --- Copy to `.env.local` (local) or set in Vercel → Project → Settings → Environment Variables ---
# Vercel: add the same keys for Production (and Preview if you use previews). Redeploy after changes.
# Use “Production” (and “Preview” if you want staging) scopes on Vercel.
# All `NEXT_PUBLIC_*` values are exposed to the browser; never put secrets in those names.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Web Push (FCM): Firebase Console → Project settings → Cloud Messaging → Web configuration → Web Push certificates → Key pair
# Used by `getToken()` and `scripts/gen-firebase-messaging-sw.mjs` to generate `public/firebase-messaging-sw.js`.
# When set, the app registers this worker instead of `public/sw.js` (offline PWA cache is skipped in production).
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# After sign-in, the app writes the Web FCM token to Firestore: `users/{uid}` (`fcmToken`, `fcmTokenUpdatedAt`).

# Capacitor Android shell: URL loaded in the WebView (deployed Next app or dev server).
# Production: https://marketplace-app-woad.vercel.app/
# Emulator → PC localhost Next dev (port 3010): http://10.0.2.2:3010
CAPACITOR_SERVER_URL=https://marketplace-app-woad.vercel.app

# Optional: Vercel injects VERCEL_URL (no protocol). This app does not require it if you use
# relative URLs only. For Firebase Authorized domains, add your production host, e.g.
# `marketplace-app-woad.vercel.app` (production) and your custom domain after you assign one.

# Cloudflare R2 (S3-compatible). Dashboard: R2 → bucket → Settings → Public access (r2.dev or custom domain)
# API token: R2 → Manage R2 API Tokens → Create with Object Read & Write on this bucket.
# R2_ACCESS_KEY_ID is exactly 32 chars (the token’s Access Key ID). R2_ACCOUNT_ID is separate (also 32 hex).
# Server-only: set on Vercel as encrypted env vars (not NEXT_PUBLIC_*).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL for the bucket (no trailing slash). Use the r2.dev or custom domain from
# R2 → your bucket → Settings → Public access — NOT *.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=

# --- Local development only (optional) ---
# If Turbopack causes issues on your machine: NEXT_DISABLE_TURBOPACK=1 next dev
# or: cross-env NEXT_DISABLE_TURBOPACK=1 next dev

# Windows: AV/sync can lock `project\.next\types` (EPERM). If `next build` fails with EPERM, use:
# `npm run build:win` (builds into `./.next-win`), or set NEXT_DIST_DIR to a *project-relative* folder
# inside the repo (must stay inside the project for Turbopack), e.g. NEXT_DIST_DIR=.next-win
