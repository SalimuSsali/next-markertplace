rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // --- Item in-app chat (strict) ---
    function convParticipants() {
      return resource.data.buyerId == request.auth.uid
        || resource.data.sellerId == request.auth.uid;
    }

    function convParticipantsCreate() {
      return request.resource.data.buyerId == request.auth.uid
        || request.resource.data.sellerId == request.auth.uid;
    }

    function convIdMatchesPayload() {
      return conversationId == request.resource.data.itemId + '__'
        + request.resource.data.buyerId + '__'
        + request.resource.data.sellerId;
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn() && convParticipants();

      allow create: if isVerified()
        && convIdMatchesPayload()
        && convParticipantsCreate()
        && request.resource.data.keys().hasAll(['itemId', 'buyerId', 'sellerId', 'createdAt'])
        && request.resource.data.itemId is string
        && request.resource.data.buyerId is string
        && request.resource.data.sellerId is string;

      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.buyerId == request.auth.uid
            || get(/databases/$(database)/documents/conversations/$(conversationId)).data.sellerId == request.auth.uid);

        allow create: if isVerified()
          && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.buyerId == request.auth.uid
            || get(/databases/$(database)/documents/conversations/$(conversationId)).data.sellerId == request.auth.uid)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.keys().hasAll(['senderId', 'text', 'createdAt']);

        allow update, delete: if false;
      }
    }

    // --- Rest of app ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /items/{itemId} {
      allow read: if true;
      // New listings require a verified email.
      allow create: if isVerified()
        && request.resource.data.keys().hasAll([
          'userId', 'createdAt', 'expiresAt', 'status'
        ])
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp;
      // Owner by userId, or legacy docs without a real userId (email match only).
      allow update, delete: if isVerified() && (
        (resource.data.keys().hasAll(['userId'])
          && resource.data.userId is string
          && resource.data.userId.size() > 0
          && resource.data.userId == request.auth.uid)
        || (
          (
            !resource.data.keys().hasAll(['userId'])
            || (resource.data.userId is string && resource.data.userId.size() == 0)
          )
          && resource.data.email is string
          && request.auth.token.email != null
          && resource.data.email.lower() == request.auth.token.email.lower()
        )
      );
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isVerified();
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isVerified();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isVerified();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isVerified();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified();
      allow update, delete: if isVerified();
    }

    match /notifications/{notificationId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
