{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    ".next-win/types/**/*.ts",
    ".next-win/dev/types/**/*.ts",
    ".next-win2/types/**/*.ts",
    ".next-win2/dev/types/**/*.ts",
    ".next-win3/types/**/*.ts",
    ".next-win3/dev/types/**/*.ts",
    ".next-ci/types/**/*.ts",
    ".next-ci/dev/types/**/*.ts",
    ".next-build2/types/**/*.ts",
    ".next-build2/dev/types/**/*.ts",
    ".next-build3/types/**/*.ts",
    ".next-build3/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "android"
  ]
}
